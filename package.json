{
  "name": "weg-shared-layout",
  "version": "0.0.54",
  "description": "Shared layout Web Components built with Stencil",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/components.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/weg-shared-layout/weg-shared-layout.esm.js",
  "exports": {
    ".": {
      "types": "./dist/types/components.d.ts",
      "import": "./dist/weg-shared-layout/weg-shared-layout.esm.js",
      "require": "./dist/weg-shared-layout/weg-shared-layout.cjs.js"
    },
    "./weg-footer": {
      "types": "./dist/components/weg-footer.d.ts",
      "import": "./dist/components/weg-footer.js"
    },
    "./weg-header": {
      "types": "./dist/components/weg-header.d.ts",
      "import": "./dist/components/weg-header.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js",
      "require": "./loader/index.cjs.js"
    },
    "./hydrate": {
      "types": "./hydrate/index.d.ts",
      "import": "./hydrate/index.mjs",
      "require": "./hydrate/index.js"
    },
    "./weg21-bootstrap.json": "./src/assets/weg21-bootstrap.json",
    "./weg21-menus.json": "./src/assets/weg21-menus.json",
    "./layout-data": {
      "types": "./dist/types/types/layout-data.d.ts"
    },
    "./menus-data": {
      "types": "./dist/types/types/menus-data.d.ts"
    },
    "./menus": {
      "types": "./src/utils/menus.ts",
      "import": "./src/utils/menus.ts",
      "default": "./src/utils/menus.ts"
    },
    "./styles/container.css": "./src/styles/container.css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jobsac/weg-shared-layout.git"
  },
  "bugs": {
    "url": "https://github.com/jobsac/weg-shared-layout/issues"
  },
  "homepage": "https://github.com/jobsac/weg-shared-layout#readme",
  "files": [
    "dist/",
    "hydrate/",
    "docs/",
    "loader/",
    "src/assets/weg21-bootstrap.json",
    "src/assets/weg21-menus.json",
    "src/utils/menus.ts",
    "src/types/menus-data.ts",
    "src/constants/",
    "src/styles/container.css"
  ],
  "scripts": {
    "prepack": "pnpm run build",
    "build": "stencil build",
    "start": "stencil build --dev --watch --serve --no-open",
    "test": "stencil-test --prod",
    "test:watch": "stencil-test --prod --watch",
    "generate": "stencil generate",
    "demo:angular16:install": "pnpm --dir demo/angular16 install",
    "demo:angular16:build": "pnpm --dir demo/angular16 run build",
    "demo:angular16": "pnpm --dir demo/angular16 run start"
  },
  "devDependencies": {
    "@csstools/postcss-global-data": "~4.0.0",
    "@stencil-community/postcss": "~2.2.0",
    "@stencil/core": "~4.43.5",
    "@stencil/vitest": "~1.8.3",
    "@types/node": "~22.13.5",
    "@vitest/browser-playwright": "~4.0.0",
    "axe-core": "~4.11.4",
    "playwright": "~1.52.0",
    "postcss-custom-media": "~12.0.1",
    "vitest": "~4.0.0"
  },
  "license": "MIT",
  "author": "WEG",
  "contributors": [
    "Tan Ahmed <tan.ahmed@warwick.ac.uk>",
    "Rakin Ahmed <rakin.ahmed@warwick.ac.uk>"
  ]
}
