{
  "name": "weg-shared-layout",
  "version": "0.0.24",
  "description": "Shared layout Web Components built with Stencil",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/components.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/weg-shared-layout/weg-shared-layout.esm.js",
  "exports": {
    ".": {
      "types": "./dist/types/components.d.ts",
      "import": "./dist/weg-shared-layout/weg-shared-layout.esm.js",
      "require": "./dist/weg-shared-layout/weg-shared-layout.cjs.js"
    },
    "./my-component": {
      "types": "./dist/components/my-component.d.ts",
      "import": "./dist/components/my-component.js"
    },
    "./weg-footer": {
      "types": "./dist/components/weg-footer.d.ts",
      "import": "./dist/components/weg-footer.js"
    },
    "./weg-header": {
      "types": "./dist/components/weg-header.d.ts",
      "import": "./dist/components/weg-header.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js",
      "require": "./loader/index.cjs.js"
    },
    "./dummy-data.json": "./src/assets/dummy-data.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jobsac/weg-shared-layout.git"
  },
  "bugs": {
    "url": "https://github.com/jobsac/weg-shared-layout/issues"
  },
  "homepage": "https://github.com/jobsac/weg-shared-layout#readme",
  "files": [
    "dist/",
    "docs/",
    "loader/",
    "src/assets/dummy-data.json",
    "src/constants/"
  ],
  "scripts": {
    "prepack": "npm run build",
    "build": "stencil build",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil-test --prod",
    "test:watch": "stencil-test --prod --watch",
    "generate": "stencil generate"
  },
  "devDependencies": {
    "@csstools/postcss-global-data": "^4.0.0",
    "@stencil-community/postcss": "^2.2.0",
    "@stencil/core": "^4.27.1 || ^5.0.0-0",
    "@stencil/vitest": "^1.8.3",
    "@types/node": "^22.13.5",
    "@vitest/browser-playwright": "^4.0.0",
    "axe-core": "^4.11.4",
    "playwright": "^1.52.0",
    "postcss-custom-media": "^12.0.1",
    "vitest": "^4.0.0"
  },
  "license": "MIT"
}
